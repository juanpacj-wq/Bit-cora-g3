# ─── Base de datos (SQL Server) ───
# NUNCA pegues credenciales reales en este archivo: es versionado. Sólo placeholders.
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433
SERVER_PORT=3002
# Cifrado del canal a SQL Server (AUD-07). Default actual NO-rompedor: tráfico en claro.
# En PRODUCCIÓN, con un certificado TLS válido instalado en SQL Server, ambas deben ir así:
#   DB_ENCRYPT=true            # cifra el canal (TDS sobre TLS).
#   DB_TRUST_SERVER_CERT=false # valida el certificado del servidor (sin esto, sigue MITM-able).
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# ─── Login Microsoft Entra ID (OIDC Auth Code + PKCE, cliente confidencial) ───
# App Registration (Azure Portal → Entra ID → App registrations). Asignación requerida = Sí.
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
# Redirect/post-logout. En dev van vía el proxy de Vite (mismo origin localhost:5174).
# Registrar AMBOS (dev y prod) en el App Registration → Authentication.
M365_REDIRECT_URI=http://localhost:5174/auth/redirect
M365_POST_LOGOUT_REDIRECT_URI=http://localhost:5174/
# Scopes (offline_access habilita el refresh token usado por la revalidación silenciosa).
M365_SCOPES=openid profile email offline_access

# Singletons de identidad (NO son App Roles): UPN del Jefe de Planta titular y del JdT por
# defecto (fallback de snapshotJDTs). Coma/espacio-separados. Vacío → fallback legacy por username.
M365_JEFE_PLANTA_UPNS=
M365_JDT_DEFAULT_UPNS=

# ─── Sesión (cookie httpOnly) ───
SESSION_SECRET=                 # `openssl rand -hex 32`. OBLIGATORIO en producción: sin él, el arranque ABORTA (AUD-22).
SESSION_COOKIE_NAME=bitacora.sid
SESSION_COOKIE_SECURE=false     # true en producción (HTTPS). En prod se fuerza por NODE_ENV.
SESSION_MAX_AGE_MS=2592000000   # 30 días.
SESSION_STORE=memory            # 'mssql' en prod (tabla [auth].[AppSessions] en el mismo SQL Server).
# AUD-13: cifrado en reposo del blob de sesión (tokens MSAL + identidad) con AES-256-GCM. Opcional:
# si se omite, la clave se DERIVA de SESSION_SECRET. Para rotación independiente, fija una de 32 bytes:
# SESSION_ENC_KEY=               # `openssl rand -hex 32` (64 hex). Rotarla invalida sesiones (re-login).
# REVALIDATE_INTERVAL_MS=1200000  # cada cuánto revalidar contra Entra (default 20 min).

# ─── Tests ───
# Backdoor SOLO para la suite de tests (resuelve la sesión por header X-Sesion-Id en vez de
# cookie). Arrancar el server de test con AUTH_TEST_BYPASS=1. NUNCA en producción.
# AUTH_TEST_BYPASS=1
# Habilita los cleanups destructivos de la suite (mand_cierre_log / evento_dashboard). Activar
# SÓLO contra una BD de test dedicada (PortalG3_test), NUNCA contra producción. Ver AUD-33.
# TEST_DB_DEDICATED=1
